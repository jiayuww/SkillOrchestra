# SkillOrchestra Environment
# Copy to .env and fill in your values.
#   cp .env.example .env

# Paths
HF_HOME=/path/to/huggingface/cache
INDEX_DIR=/path/to/retrieval/index

# API Keys (required for LLM calls during learning)
OPENAI_API_KEY=
# OPENAI_GATEWAY_KEY=

# Optional: for retrieval
TAVILY_KEY=

# Optional: for alternative model providers
# TOGETHER_API_KEY=
# GEMINI_API_KEY=
# HUGGINGFACE_TOKEN=
